# Git
.git
.gitignore
.gitattributes

# Dependencias (Se deben instalar DENTRO del contenedor para evitar conflictos OS/Arquitectura)
/vendor
/node_modules

# Variables de entorno (Seguridad: Nunca deben ir dentro de la imagen estática)
.env
.env.*
!.env.example

# Archivos de caché y logs de Laravel (Evita copiar basura local)
/storage/logs/*
!/storage/logs/.gitignore
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# Archivos de logs de Node/NPM
npm-debug.log
yarn-error.log
yarn-debug.log

# Archivos de configuración de IDEs y OS local
.idea/
.vscode/
.DS_Store
Thumbs.db

# Documentación y orquestación (No son necesarios dentro del contenedor PHP)
/lalysdent/
docker-compose.yml
docker-compose/
README.md
phpunit.xml